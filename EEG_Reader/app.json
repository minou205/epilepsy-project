{
  "expo": {
    "name": "epilepsy",
    "slug": "epilepsy",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#080818"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow EEG Reader to access your camera to scan QR codes."
        }
      ],
      "expo-notifications"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.student.eegreader",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#080818"
      },
      "package": "com.minou.eegreader",
      "versionCode": 12,
      "permissions": [
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "014ab87d-807f-45a6-b754-3174057e2a9a"
      }
    },
    "owner": "minou205s-organization"
  }
}
